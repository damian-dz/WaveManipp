# Doxygen configuration for WaveManipp
# Run: doxygen Doxyfile   (from this directory)
# Output: docs/html/index.html

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME        = "WaveManipp"
PROJECT_BRIEF       = "C++ audio manipulation library"
PROJECT_NUMBER      =
OUTPUT_DIRECTORY    = dox

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT               = api \
                      src \
                      README.md
FILE_PATTERNS       = *.h *.hpp *.cpp
RECURSIVE           = NO
USE_MDFILE_AS_MAINPAGE = README.md

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
# All public symbols are documented; enable EXTRACT_ALL to also pick up
# anything that lacks a doc comment (useful for first-pass generation).
EXTRACT_ALL         = YES
EXTRACT_PRIVATE     = NO
EXTRACT_STATIC      = YES
HIDE_UNDOC_MEMBERS  = NO
HIDE_UNDOC_CLASSES  = NO

#---------------------------------------------------------------------------
# Build
#---------------------------------------------------------------------------
SORT_MEMBER_DOCS    = NO
SHOW_INCLUDE_FILES  = YES
INLINE_SOURCES      = NO
STRIP_CODE_COMMENTS = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET               = NO
WARNINGS            = YES
WARN_IF_UNDOCUMENTED = YES
WARN_IF_DOC_ERROR   = YES

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML       = YES
HTML_OUTPUT         = html
HTML_TIMESTAMP      = NO
HTML_EXTRA_STYLESHEET = docs-extra.css
GENERATE_TREEVIEW   = YES
TREEVIEW_WIDTH      = 250
SEARCHENGINE        = YES

#---------------------------------------------------------------------------
# Disabled outputs
#---------------------------------------------------------------------------
GENERATE_LATEX      = NO
GENERATE_RTF        = NO
GENERATE_MAN        = NO
GENERATE_XML        = NO

#---------------------------------------------------------------------------
# Graphs (requires Graphviz dot; set HAVE_DOT = NO if not installed)
#---------------------------------------------------------------------------
HAVE_DOT            = NO
CLASS_DIAGRAMS      = YES
